# GMP Platform — Environment Configuration Template
# Copy this file to .env and fill in all values before starting the application.
# NEVER commit .env to version control.
#
# Regulatory note: Production SECRET_KEY and database credentials must be
# managed through an approved secrets management system (e.g. HashiCorp Vault,
# AWS Secrets Manager). Access to credentials is itself an auditable event.

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=GMP Platform
APP_VERSION=0.1.0

# Set to "production" for live environments. Controls: docs UI visibility,
# log verbosity, and DEBUG mode.
ENVIRONMENT=development
DEBUG=true

# ── Database ──────────────────────────────────────────────────────────────────
# Async driver (used by FastAPI application)
DATABASE_URL=postgresql+asyncpg://gmp_user:CHANGE_ME@localhost:5432/gmp_platform
# Sync driver (used by Alembic migrations only)
DATABASE_URL_SYNC=postgresql://gmp_user:CHANGE_ME@localhost:5432/gmp_platform

# ── Redis ─────────────────────────────────────────────────────────────────────
# Used by APScheduler job store and future caching/Celery integration
REDIS_URL=redis://localhost:6379/0

# ── Security (21 CFR Part 11 §11.10(d)) ──────────────────────────────────────
# Minimum 32 characters. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_with_secrets_token_hex_32

# JWT algorithm for access tokens
ALGORITHM=HS256

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Electronic Signatures (21 CFR Part 11 §11.200) ────────────────────────────
# RSA key paths for e-signature JWT tokens.
# Generate with: openssl genrsa -out esig_private.pem 2048
#                openssl rsa -in esig_private.pem -pubout -out esig_public.pem
ESIG_ALGORITHM=RS256
ESIG_PRIVATE_KEY_PATH=/run/secrets/esig_private.pem
ESIG_PUBLIC_KEY_PATH=/run/secrets/esig_public.pem

# ── Session and Login Policy (21 CFR Part 11 §11.10(d)) ──────────────────────
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# ── Password Policy ───────────────────────────────────────────────────────────
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true
# Number of previous passwords that cannot be reused
PASSWORD_HISTORY_COUNT=12

# ── Audit Log Retention (EU GMP Annex 11 §17) ─────────────────────────────────
# Audit events must be retained for a minimum of this many years.
AUDIT_LOG_RETENTION_YEARS=10
